# =============================================================================
# Memórias em Vídeo — Configuração de Produção
# =============================================================================
# Copie este arquivo para .env.production e preencha os valores

# --- Banco de Dados ---
DATABASE_URL=postgresql+asyncpg://memoria:SUA_SENHA_AQUI@postgres:5432/memoria_video
MONGODB_URL=mongodb://mongodb:27017/memoria_video
REDIS_URL=redis://redis:6379/0

# --- Debug ---
DEBUG=false
SECRET_KEY=gerar-uma-chave-aleatoria-forte-aqui

# --- Chatwoot (WhatsApp) ---
# URL do Chatwoot self-hosted (já instalado no cluster)
CHATWOOT_API_URL=https://chat.pelagus.com.br
# Account ID da conta 'PessoalHaroldo' (a que tem o WhatsApp configurado)
CHATWOOT_ACCOUNT_ID=4
# Token gerado em Chatwoot > Settings > Account > API > Generate Access Token
CHATWOOT_API_TOKEN=token-aqui

# --- Webhooks do Chatwoot ---
# O webhook do Chatwoot inbox 18 (Whts, WhatsApp API) já aponta para:
#   https://webhooks.pelagus.com.br/webhook/6a936a6e-9056-465a-934f-e46564e5cbd4
# Para o backend do Memória em Vídeo receber as mensagens:
#   Adicione outro webhook em Chatwoot > Settings > Account > Webhooks
#   URL: https://memoria.pelagus.com.br/webhooks/chatwoot/message
#   Eventos: message_created
#
# --- WhatsApp ---
# O número de WhatsApp atualmente em uso NÃO está na base do Chatwoot
# porque o canal é Channel::Api (integrado via UaZapi ou n8n).
# Para descobrir o número:
#   1. Verifique no n8n o workflow que recebe webhook:
#      https://webhooks.pelagus.com.br/webhook/6a936a6e-9056-465a-934f-e46564e5cbd4
#   2. Ou verifique o UaZapi em https://app.uazapi.com
#   3. Ou pergunte ao admin qual número está conectado
#
# --- JWT ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@memoriavideo.com
ADMIN_PASSWORD=hash-da-senha-aqui

# --- IA ---
ANTHROPIC_API_KEY=sk-ant-aqui
OPENAI_API_KEY=
